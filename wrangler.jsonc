{
  "name": "delight-billing-tool",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-09",
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "billing.delight-residential.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*"
    ]
  }
}
