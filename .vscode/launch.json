{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Legacy Streamlit App",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "legacy/streamlit_app.py",
        "--server.port=8501",
        "--server.enableCORS=false",
        "--server.enableXsrfProtection=false"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Worker App (Wrangler Dev)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run-script",
        "dev"
      ],
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Worker Smoke Test",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run-script",
        "test:smoke"
      ],
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ],
  "compounds": [
    {
      "name": "Run All Apps",
      "configurations": [
        "Legacy Streamlit App",
        "Worker App (Wrangler Dev)"
      ]
    }
  ]
}
